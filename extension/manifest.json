{
  "manifest_version": 3,
  "name": "X to xcancel Redirect",
  "version": "0.1.0",
  "description": "Redirect x.com and twitter.com links to xcancel.com.",
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*"
      ],
      "js": [
        "src/content-redirect.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "X to xcancel Redirect"
  }
}
